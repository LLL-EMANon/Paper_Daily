# 忽略所有文件
*

# 但保留 papers 目录下的 .md 文件
!papers/
!papers/*.md

# 保留 .gitignore 文件本身
!.gitignore

# 忽略编辑器临时文件
.vscode/
.idea/
*.swp
*.swo

# 忽略日志文件
*.log

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略压缩包和二进制文件
*.zip
*.tar
*.gz
*.7z
*.exe
*.dll
*.so
*.dylib

# 忽略环境相关文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 忽略依赖目录
node_modules/
venv/
__pycache__/
*.pyc
